<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.chatroom.tieba.mapper.UserProfileMapper">

    <insert id="insert">
        INSERT INTO forum_user_profile(user_id, nickname, avatar, bio)
        VALUES(#{userId}, #{nickname}, #{avatar}, #{bio})
    </insert>

    <select id="findByUserId" resultType="UserProfile">
        SELECT * FROM forum_user_profile WHERE user_id = #{userId}
    </select>

</mapper>